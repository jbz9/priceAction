//@version=6
// VWAP PA - Brooks v1.3 (2026-05) | ES/XAUUSD/NQ | 1m/5m/15m
// VWAP 回调 + Brooks 强 K → 下一根挂止损单入场
// Auto Anchor（日内→Day, D→Week, W→Month）| 仅显示当天 VWAP 段
// SL/TP: line + label（与 EMA PA 完全一致）| 信号: ● 圆形
//
// 已知风险：
// - anchorReset 跟随 exchange 日界，与 sessionStr 时区可能不对齐
//   （上海 9:00 开盘瞬间 VWAP 含 NY 收盘后亚盘累积，非纯日内起锚）
// - 信号 ● 标签与 Stop 标签共用 allLabels 数组，maxSignals 在 showSL on/off 时实际上限不同
//
// 变更日志：
// v1.3 (2026-05):
//   - 移除 ±σ 带相关 inputs / plots / fills（UI 精简）
//   - 4 个状态清空块合并为 1 个 reset 块（DRY）
//   - ta.vwap 简化为二参数版（不再需要带）
//   - SL line 创建改用 ternary 赋值，与 EMA PA 风格完全对齐
// v1.2 (2026-05): 时段默认上海 9:00-23:00, 视觉对齐 TV 内置 VWAP AA
// v1.1 (2026-05): SL/TP line + label
// v1.0 (2026-05): 初版

indicator("VWAP PA - Brooks", overlay=true, max_labels_count=500, max_lines_count=500)

// ── Inputs ──────────────────────────────────────────────────────────────────

gr0 = "Signal Logic"
strictPA        = input.bool (true,  "严格 K 线质量过滤", group=gr0, tooltip="实体>0.5×range，影线<实体")
slopeFilter     = input.bool (true,  "VWAP 斜率过滤", group=gr0)
slopeBars       = input.int  (5,     "斜率窗口", minval=2, group=gr0)
slopeAtrMul     = input.float(0.05,  "斜率阈值 ATR 倍数", minval=0.0, step=0.01, group=gr0)
contactAtrMul   = input.float(0.30,  "触碰容忍度 ATR 倍数", minval=0.0, step=0.05, group=gr0)
contactLookback = input.int  (5,     "触碰回溯 N 根", minval=1, group=gr0)
maxSignals      = input.int  (5,     "显示信号组数", minval=1, group=gr0)
lockTimeout     = input.int  (1,     "挂单有效 K 线数", minval=1, group=gr0)

gr1 = "VWAP"
showVWAP  = input.bool (true, "显示 VWAP", group=gr1)
todayOnly = input.bool (false, "仅显示当前 anchor 段", group=gr1, tooltip="关闭(默认) = 显示全部历史段，与 TV 内置 VWAP AA 视觉一致；开启 = 仅显示今天/本周")
vwapColor = input.color(color.new(color.blue, 0), "颜色", group=gr1)
vwapWidth = input.int  (2, "宽度", minval=1, maxval=4, group=gr1)

gr2 = "ATR"
atrLen = input.int(14, "ATR Length", minval=1, group=gr2)

gr3 = "Stop Loss"
stopMode  = input.string("Signal Bar", "Stop Mode", options=["Signal Bar","Swing Pivot"], group=gr3)
swingLook = input.int (5, "Swing Lookback", minval=2, group=gr3)
showSL    = input.bool(true, "显示止损线", group=gr3)

gr4 = "Take Profit"
showTP  = input.bool (true, "显示止盈线", group=gr4)
tpRrR1  = input.float(1.0, "TP1 R 倍数", minval=0.1, step=0.1, group=gr4)
tpRrR2  = input.float(2.0, "TP2 R 倍数", minval=0.1, step=0.1, group=gr4)
tp1Col  = input.color(color.new(color.teal, 0), "1R 颜色", group=gr4)
tp2Col  = input.color(color.new(color.blue, 0), "2R 颜色", group=gr4)
tpWidth = input.int  (2, "线宽", minval=1, maxval=4, group=gr4)
tpStyle = input.string("Solid", "线型", options=["Solid","Dashed","Dotted"], group=gr4)

gr5 = "Signal Styling"
sizeOpt = input.string("大", "图形大小", options=["中","大"], group=gr5)
bullCol = input.color(color.green, "Buy Color", group=gr5)
bearCol = input.color(color.red, "Sell Color", group=gr5)

grPanel = "Info Panel"
showPanel = input.bool(true, "显示面板", group=grPanel)

gr6 = "Trading Hours"
sessionFilter = input.bool(true, "启用时段过滤", group=gr6)
sessionStr    = input.session("0900-2300:1234567", "时段", group=gr6)
sessionTzOpt  = input.string("Asia/Shanghai", "时区", options=["America/New_York","Asia/Shanghai","Asia/Tokyo","Europe/London","exchange"], group=gr6)

// ── Helpers ─────────────────────────────────────────────────────────────────

f_sizeVal(opt) =>
    switch opt
        "中" => size.normal
        "大" => size.large
        => size.normal

f_lineStyle(s) =>
    switch s
        "Solid"  => line.style_solid
        "Dashed" => line.style_dashed
        "Dotted" => line.style_dotted
        =>          line.style_dashed

// ── Data ────────────────────────────────────────────────────────────────────

anchorReset = timeframe.isintraday ? timeframe.change("D") : timeframe.isdaily ? timeframe.change("W") : timeframe.isweekly ? timeframe.change("M") : timeframe.change("12M")

sameDay   = year(time) == year(timenow) and month(time) == month(timenow) and dayofmonth(time) == dayofmonth(timenow)
sameWeek  = math.floor(time / 604800000.0) == math.floor(timenow / 604800000.0)
sameMonth = year(time) == year(timenow) and month(time) == month(timenow)
sameYear  = year(time) == year(timenow)
inCurrentSegment = timeframe.isintraday ? sameDay : timeframe.isdaily ? sameWeek : timeframe.isweekly ? sameMonth : sameYear
// todayOnly=false (默认) → 全部历史段都画（TV AA 风格）；todayOnly=true → 仅当前段
isInActiveAnchor = todayOnly ? inCurrentSegment : true

vwapVal = ta.vwap(hlc3, anchorReset)
atr     = ta.atr(atrLen)

plot(showVWAP and isInActiveAnchor ? vwapVal : na, "VWAP", color=vwapColor, linewidth=vwapWidth)

// ── Calcs ───────────────────────────────────────────────────────────────────

vwapSlopeRaw = atr > 0 and not na(vwapVal[slopeBars]) ? (vwapVal - vwapVal[slopeBars]) / atr : 0.0
vwapUp   = slopeFilter ? vwapSlopeRaw >  slopeAtrMul : true
vwapDown = slopeFilter ? vwapSlopeRaw < -slopeAtrMul : true

barRange   = high - low
bodySize   = math.abs(close - open)
upperTail  = high - math.max(close, open)
lowerTail  = math.min(close, open) - low
midPoint   = (high + low) / 2
validRange = barRange > syminfo.mintick

qBull = validRange and bodySize > barRange * 0.5 and upperTail < bodySize and close > midPoint
qBear = validRange and bodySize > barRange * 0.5 and lowerTail < bodySize and close < midPoint

isBullSig = strictPA ? (close > open and qBull) : (close > open)
isBearSig = strictPA ? (close < open and qBear) : (close < open)

// ── VWAP Contact ────────────────────────────────────────────────────────────

buyContactNow  = low  <= vwapVal + atr * contactAtrMul and close > vwapVal
sellContactNow = high >= vwapVal - atr * contactAtrMul and close < vwapVal

barsSinceLowBelow  = ta.barssince(low  <= vwapVal)
barsSinceHighAbove = ta.barssince(high >= vwapVal)

priorBuyContact  = not na(barsSinceLowBelow)  and barsSinceLowBelow  >= 1 and barsSinceLowBelow  <= contactLookback and close > vwapVal
priorSellContact = not na(barsSinceHighAbove) and barsSinceHighAbove >= 1 and barsSinceHighAbove <= contactLookback and close < vwapVal

vwapContactBuy  = buyContactNow  or priorBuyContact
vwapContactSell = sellContactNow or priorSellContact

sessionTz = sessionTzOpt == "exchange" ? syminfo.timezone : sessionTzOpt
inSession = sessionFilter ? not na(time(timeframe.period, sessionStr, sessionTz)) : true

// ── Signal ──────────────────────────────────────────────────────────────────

isSignalBarBuy  = vwapUp   and vwapContactBuy  and isBullSig
isSignalBarSell = vwapDown and vwapContactSell and isBearSig

confirmed = barstate.isconfirmed

// ── State Machine ───────────────────────────────────────────────────────────

var int   positionState = 0
var int   signalBarIdx  = na
var float entryPrice    = na
var float slPrice       = na
var float tp1Price      = na
var float tp2Price      = na
var bool  isFilled      = false

buySig  = confirmed and isSignalBarBuy  and positionState == 0 and inSession
sellSig = confirmed and isSignalBarSell and positionState == 0 and inSession

swingBuyStop  = ta.lowest (low,  swingLook)
swingSellStop = ta.highest(high, swingLook)

if buySig
    positionState := 1
    signalBarIdx  := bar_index
    entryPrice    := high + syminfo.mintick
    slPrice       := stopMode == "Signal Bar" ? low - syminfo.mintick : math.min(low, swingBuyStop) - syminfo.mintick
    float riskR   = entryPrice - slPrice
    tp1Price      := entryPrice + riskR * tpRrR1
    tp2Price      := entryPrice + riskR * tpRrR2
    isFilled      := false

if sellSig
    positionState := -1
    signalBarIdx  := bar_index
    entryPrice    := low - syminfo.mintick
    slPrice       := stopMode == "Signal Bar" ? high + syminfo.mintick : math.max(high, swingSellStop) + syminfo.mintick
    float riskR   = slPrice - entryPrice
    tp1Price      := entryPrice - riskR * tpRrR1
    tp2Price      := entryPrice - riskR * tpRrR2
    isFilled      := false

canManage = positionState != 0 and not na(signalBarIdx) and bar_index > signalBarIdx

if canManage and not isFilled
    if positionState == 1 and high >= entryPrice
        isFilled := true
    if positionState == -1 and low <= entryPrice
        isFilled := true

// ── Exit / Cancel / Reverse → 单一 reset 块 ────────────────────────────────

hitExitLong  = positionState ==  1 and (low  <= slPrice or high >= tp2Price)
hitExitShort = positionState == -1 and (high >= slPrice or low  <= tp2Price)
hitExit      = canManage and isFilled and (hitExitLong or hitExitShort)

barsSinceSignal = na(signalBarIdx) ? na : bar_index - signalBarIdx
shouldCancel    = positionState != 0 and not isFilled and not na(barsSinceSignal) and barsSinceSignal >= lockTimeout

reverseUnlock = confirmed and ((positionState == 1 and isSignalBarSell) or (positionState == -1 and isSignalBarBuy))

shouldReset = hitExit or shouldCancel or reverseUnlock
if shouldReset
    positionState := 0
    signalBarIdx  := na
    entryPrice    := na
    slPrice       := na
    tp1Price      := na
    tp2Price      := na
    isFilled      := false

// ── Visualization ───────────────────────────────────────────────────────────

var line  buySLLine    = na
var line  sellSLLine   = na
var line  buyTP1Line   = na
var line  buyTP2Line   = na
var line  sellTP1Line  = na
var line  sellTP2Line  = na
var label buyTP1Label  = na
var label buyTP2Label  = na
var label sellTP1Label = na
var label sellTP2Label = na

var label[] allLabels  = array.new<label>()
var line[]  allSLLines = array.new<line>()

f_pushLabel(_lb) =>
    array.push(allLabels, _lb)
    if array.size(allLabels) > maxSignals * 2
        label.delete(array.shift(allLabels))

f_pushSLLine(_ln) =>
    array.push(allSLLines, _ln)
    if array.size(allSLLines) > maxSignals
        line.delete(array.shift(allSLLines))

f_deleteLine(ln) =>
    if not na(ln)
        line.delete(ln)

f_deleteLabel(lb) =>
    if not na(lb)
        label.delete(lb)

if buySig
    f_pushLabel(label.new(bar_index, low, "●", style=label.style_none, textcolor=bullCol, size=f_sizeVal(sizeOpt), yloc=yloc.belowbar))
    buySLLine := showSL and not na(slPrice) ? line.new(bar_index, slPrice, bar_index + 1, slPrice, color=color.red, width=tpWidth, style=f_lineStyle(tpStyle)) : na
    if showSL and not na(slPrice)
        f_pushSLLine(buySLLine)
        f_pushLabel(label.new(bar_index, slPrice, "Stop", style=label.style_none, textcolor=color.red, size=size.small, yloc=yloc.price))
    if showTP and not na(tp1Price) and not na(tp2Price)
        f_deleteLine(buyTP1Line)
        f_deleteLine(buyTP2Line)
        f_deleteLine(sellTP1Line)
        f_deleteLine(sellTP2Line)
        f_deleteLabel(buyTP1Label)
        f_deleteLabel(buyTP2Label)
        f_deleteLabel(sellTP1Label)
        f_deleteLabel(sellTP2Label)
        sellTP1Line  := na
        sellTP2Line  := na
        sellTP1Label := na
        sellTP2Label := na
        buyTP1Line  := line.new(bar_index, tp1Price, bar_index + 1, tp1Price, color=tp1Col, width=tpWidth, style=f_lineStyle(tpStyle))
        buyTP2Line  := line.new(bar_index, tp2Price, bar_index + 1, tp2Price, color=tp2Col, width=tpWidth, style=f_lineStyle(tpStyle))
        buyTP1Label := label.new(bar_index, tp1Price, "1R", style=label.style_none, textcolor=tp1Col, size=size.small, yloc=yloc.price)
        buyTP2Label := label.new(bar_index, tp2Price, "2R", style=label.style_none, textcolor=tp2Col, size=size.small, yloc=yloc.price)

if sellSig
    f_pushLabel(label.new(bar_index, high, "●", style=label.style_none, textcolor=bearCol, size=f_sizeVal(sizeOpt), yloc=yloc.abovebar))
    sellSLLine := showSL and not na(slPrice) ? line.new(bar_index, slPrice, bar_index + 1, slPrice, color=color.red, width=tpWidth, style=f_lineStyle(tpStyle)) : na
    if showSL and not na(slPrice)
        f_pushSLLine(sellSLLine)
        f_pushLabel(label.new(bar_index, slPrice, "Stop", style=label.style_none, textcolor=color.red, size=size.small, yloc=yloc.price))
    if showTP and not na(tp1Price) and not na(tp2Price)
        f_deleteLine(buyTP1Line)
        f_deleteLine(buyTP2Line)
        f_deleteLine(sellTP1Line)
        f_deleteLine(sellTP2Line)
        f_deleteLabel(buyTP1Label)
        f_deleteLabel(buyTP2Label)
        f_deleteLabel(sellTP1Label)
        f_deleteLabel(sellTP2Label)
        buyTP1Line  := na
        buyTP2Line  := na
        buyTP1Label := na
        buyTP2Label := na
        sellTP1Line  := line.new(bar_index, tp1Price, bar_index + 1, tp1Price, color=tp1Col, width=tpWidth, style=f_lineStyle(tpStyle))
        sellTP2Line  := line.new(bar_index, tp2Price, bar_index + 1, tp2Price, color=tp2Col, width=tpWidth, style=f_lineStyle(tpStyle))
        sellTP1Label := label.new(bar_index, tp1Price, "1R", style=label.style_none, textcolor=tp1Col, size=size.small, yloc=yloc.price)
        sellTP2Label := label.new(bar_index, tp2Price, "2R", style=label.style_none, textcolor=tp2Col, size=size.small, yloc=yloc.price)

if positionState == 1
    if not na(buySLLine)
        line.set_x2(buySLLine, bar_index)
    if showTP
        if not na(buyTP1Line)
            line.set_x2(buyTP1Line, bar_index)
        if not na(buyTP2Line)
            line.set_x2(buyTP2Line, bar_index)

if positionState == -1
    if not na(sellSLLine)
        line.set_x2(sellSLLine, bar_index)
    if showTP
        if not na(sellTP1Line)
            line.set_x2(sellTP1Line, bar_index)
        if not na(sellTP2Line)
            line.set_x2(sellTP2Line, bar_index)

// ── Alerts ──────────────────────────────────────────────────────────────────

alertcondition(buySig,  title="VWAP PA Buy Setup",  message="VWAP PA Brooks: BUY setup")
alertcondition(sellSig, title="VWAP PA Sell Setup", message="VWAP PA Brooks: SELL setup")

var bool isFilledPrev = false
buyFilled  = confirmed and positionState ==  1 and isFilled and not isFilledPrev
sellFilled = confirmed and positionState == -1 and isFilled and not isFilledPrev
isFilledPrev := isFilled
alertcondition(buyFilled,  title="VWAP PA Buy Filled",  message="VWAP PA Brooks: Buy Stop FILLED")
alertcondition(sellFilled, title="VWAP PA Sell Filled", message="VWAP PA Brooks: Sell Stop FILLED")

// ── Panel ───────────────────────────────────────────────────────────────────

stateText  = positionState == 1 ? (isFilled ? "LONG Filled" : "Long Armed") : positionState == -1 ? (isFilled ? "SHORT Filled" : "Short Armed") : "FLAT"
stateColor = positionState == 1 ? color.new(color.green, 30) : positionState == -1 ? color.new(color.red, 30) : color.new(color.gray, 30)
trendText  = vwapUp ? "VWAP Up" : vwapDown ? "VWAP Down" : "Flat"
sessionText  = sessionFilter ? (inSession ? "IN" : "OUT") : "OFF"
sessionColor = sessionFilter ? (inSession ? color.new(color.green, 30) : color.new(color.maroon, 30)) : color.new(color.gray, 30)

var table panel = table.new(position.top_right, 2, 4, border_width=1)
if showPanel and barstate.islast
    table.cell(panel, 0, 0, "Trend",   text_color=color.white, bgcolor=color.new(color.gray, 50))
    table.cell(panel, 1, 0, trendText, text_color=color.white, bgcolor=color.new(color.gray, 30))
    table.cell(panel, 0, 1, "State",   text_color=color.white, bgcolor=color.new(color.gray, 50))
    table.cell(panel, 1, 1, stateText, text_color=color.white, bgcolor=stateColor)
    table.cell(panel, 0, 2, "Session", text_color=color.white, bgcolor=color.new(color.gray, 50))
    table.cell(panel, 1, 2, sessionText, text_color=color.white, bgcolor=sessionColor)
    table.cell(panel, 0, 3, "Slope",   text_color=color.white, bgcolor=color.new(color.gray, 50))
    table.cell(panel, 1, 3, str.tostring(vwapSlopeRaw, "#.###"), text_color=color.white, bgcolor=color.new(color.gray, 30))
