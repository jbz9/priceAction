//@version=6
// =============================================================================
// VWAP PA - Brooks  v1.0  (2026-05)
// 适用品种 : ES / XAUUSD / NQ 等流动性高的日内品种
// 适用周期 : 1m / 5m / 15m
// 状态     : 草稿 → 待回测验证
//
// 设计意图:
//   在 Brooks 价格行为框架下，使用 VWAP（成交量加权均价）作为价格回调的基准。
//   当价格从一侧回撤至 VWAP 并出现强 PA 信号 K（多头收阳 / 空头收阴），
//   在信号 K 的下一根 K 线挂止损单入场（Buy Stop / Sell Stop）。
//
// 触发流程:
//   ① VWAP 斜率过滤：多头要求 VWAP 向上，空头要求 VWAP 向下
//   ② 价格回调触碰 VWAP（当根直接触碰或近 N 根内有触碰记录）
//   ③ 信号 K 收回 VWAP 上 / 下方，且符合 Brooks 强 K 质量
//   ④ 信号 K 收盘时绘制 setup（箭头 + SL 框 + TP1 / TP2 框）
//   ⑤ 下一根 K 突破信号 K 高 / 低 → 视为挂单触发；超过 N 根未破 → 撤单失效
//
// 与 EMA_PA_Brooks 的区别:
//   - 趋势过滤    : VWAP 斜率（单线）        vs. EMA20 / 49 双均线
//   - 入场触发    : 下一根 K 挂止损单          vs. 当前 K close 突破 prev high
//   - SL/TP 可视化 : box 矩形区域             vs. line 水平线
//
// 变更日志:
//   v1.0 (2026-05): 初版
//     - VWAP anchor 可选 Session / Week / Month
//     - 信号 K 收盘即画 setup，挂单超时自动撤单
//     - 状态机：flat → armed → filled → closed，含反向信号解锁
// =============================================================================

indicator("VWAP PA - Brooks", overlay=true,
          max_labels_count=500, max_lines_count=500, max_boxes_count=500)

// ─────────────────────────────────────────────────────────────────────────────
// 3. Inputs
// ─────────────────────────────────────────────────────────────────────────────

gr0 = "Signal Logic"
strictPA        = input.bool (true,  "严格 K 线质量过滤",
     group=gr0, tooltip="开启后要求信号 K 实体>0.5×range，影线<实体，收盘在强方向 30% 区域")
slopeFilter     = input.bool (true,  "VWAP 斜率过滤",
     group=gr0, tooltip="多头要求 VWAP 向上，空头要求 VWAP 向下")
slopeBars       = input.int  (5,     "VWAP 斜率窗口（K 线数）",      minval=2,
     group=gr0)
slopeAtrMul     = input.float(0.05,  "VWAP 斜率最小阈值 ATR 倍数",   minval=0.0, step=0.01,
     group=gr0, tooltip="|VWAP - VWAP[N]| / ATR 的最小值；过滤横盘中的 VWAP 噪音")
contactAtrMul   = input.float(0.30,  "回调触碰容忍度 ATR 倍数",      minval=0.0, step=0.05,
     group=gr0, tooltip="信号 K 与 VWAP 距离 ≤ 该值视为完成回调触碰")
contactLookback = input.int  (5,     "近 N 根触碰回溯",              minval=1,
     group=gr0, tooltip="信号 K 当根可未直接触碰，但近 N 根中需有触碰记录")
maxSignals      = input.int  (5,     "最近显示信号组数",             minval=1,
     group=gr0)
lockTimeout     = input.int  (1,     "挂单有效 K 线数",              minval=1,
     group=gr0, tooltip="信号 K 后 N 根仍未触发即视为失效（默认 1 = 仅下一根）")

gr1 = "VWAP"
vwapAnchorOpt = input.string("Session", "VWAP Anchor",
     options=["Session","Week","Month"],
     group=gr1, tooltip="重置周期：Session=每日重置，Week=每周一重置，Month=每月一日重置")
showVWAP      = input.bool (true,                     "显示 VWAP 线",         group=gr1)
vwapColor     = input.color(color.new(color.blue, 0), "VWAP 颜色",            group=gr1)
vwapWidth     = input.int  (2,                        "VWAP 宽度",
     minval=1, maxval=4, group=gr1)

gr2 = "ATR"
atrLen = input.int(14, "ATR Length", minval=1, group=gr2)

gr3 = "Stop Loss"
stopMode  = input.string("Signal Bar", "Stop Mode",
     options=["Signal Bar","Swing Pivot"], group=gr3,
     tooltip="Signal Bar = 信号 K 高 / 低 ± 1 tick；Swing Pivot = 近 N 根摆动极值")
swingLook = input.int (5,    "Swing Pivot Lookback", minval=2, group=gr3)
showSL    = input.bool(true, "显示止损区域",                   group=gr3)

gr4 = "Take Profit"
showTP      = input.bool (true,  "显示止盈区域",                                 group=gr4)
tpRrR1      = input.float(1.0,   "TP1 R 倍数",          minval=0.1, step=0.1,    group=gr4)
tpRrR2      = input.float(2.0,   "TP2 R 倍数",          minval=0.1, step=0.1,    group=gr4)
boxWidth    = input.int  (8,     "SL/TP 框宽（K 线数）",
     minval=2, maxval=50, group=gr4)
slBoxColor  = input.color(color.new(color.red,  80), "SL 框背景色",  group=gr4)
tp1BoxColor = input.color(color.new(color.teal, 75), "TP1 框背景色", group=gr4)
tp2BoxColor = input.color(color.new(color.teal, 85), "TP2 框背景色", group=gr4)
borderTrans = input.int  (60,                          "框线透明度",
     minval=0, maxval=100, group=gr4)

gr5 = "Signal Styling"
shapeOpt = input.string("箭头", "信号形状",
     options=["箭头","圆形","正方形","菱形","十字"], group=gr5)
sizeOpt  = input.string("中",   "图形大小",
     options=["小","中","大","巨大"], group=gr5)
bullCol  = input.color (color.green, "Buy Color",  group=gr5)
bearCol  = input.color (color.red,   "Sell Color", group=gr5)

grPanel = "Info Panel"
showPanel = input.bool(true, "显示状态面板", group=grPanel)

// ─────────────────────────────────────────────────────────────────────────────
// 4. Helper
// ─────────────────────────────────────────────────────────────────────────────

f_size(opt) =>
    switch opt
        "小"   => size.small
        "中"   => size.normal
        "大"   => size.large
        "巨大" => size.huge
        => size.normal

f_bullChar(opt) =>
    switch opt
        "圆形"   => "●"
        "正方形" => "■"
        "菱形"   => "◆"
        "十字"   => "✚"
        "箭头"   => "▲"
        => "▲"

f_bearChar(opt) =>
    switch opt
        "圆形"   => "●"
        "正方形" => "■"
        "菱形"   => "◆"
        "十字"   => "✚"
        "箭头"   => "▼"
        => "▼"

f_anchorTrigger() =>
    switch vwapAnchorOpt
        "Session" => timeframe.change("D")
        "Week"    => timeframe.change("W")
        "Month"   => timeframe.change("M")
        =>           timeframe.change("D")

// ─────────────────────────────────────────────────────────────────────────────
// 5. Data
// ─────────────────────────────────────────────────────────────────────────────

anchorTrigger = f_anchorTrigger()

vwapSrc = ta.vwap(hlc3, anchorTrigger)
atr     = ta.atr(atrLen)

plot(showVWAP ? vwapSrc : na, "VWAP", color=vwapColor, linewidth=vwapWidth)

// ─────────────────────────────────────────────────────────────────────────────
// 6. Mid calcs
// ─────────────────────────────────────────────────────────────────────────────

vwapSlopeRaw = atr > 0 and not na(vwapSrc[slopeBars]) ? (vwapSrc - vwapSrc[slopeBars]) / atr : 0.0
vwapUp   = slopeFilter ? vwapSlopeRaw >  slopeAtrMul : true
vwapDown = slopeFilter ? vwapSlopeRaw < -slopeAtrMul : true

barRange   = high - low
bodySize   = math.abs(close - open)
upperTail  = high - math.max(close, open)
lowerTail  = math.min(close, open) - low
midPoint   = (high + low) / 2
validRange = barRange > syminfo.mintick

qBull = validRange and bodySize > barRange * 0.5 and upperTail < bodySize and close > midPoint
qBear = validRange and bodySize > barRange * 0.5 and lowerTail < bodySize and close < midPoint

isBullSig = strictPA ? (close > open and qBull) : (close > open)
isBearSig = strictPA ? (close < open and qBear) : (close < open)

// ─────────────────────────────────────────────────────────────────────────────
// 7. Context: VWAP contact (回调企稳判定)
// ─────────────────────────────────────────────────────────────────────────────

// 7.1 当根直接触碰
buyContactNow  = low  <= vwapSrc + atr * contactAtrMul and close > vwapSrc
sellContactNow = high >= vwapSrc - atr * contactAtrMul and close < vwapSrc

// 7.2 近 N 根历史触碰
barsSinceLowBelow  = ta.barssince(low  <= vwapSrc)
barsSinceHighAbove = ta.barssince(high >= vwapSrc)

priorBuyContact  = not na(barsSinceLowBelow)  and barsSinceLowBelow  >= 1 and barsSinceLowBelow  <= contactLookback and close > vwapSrc
priorSellContact = not na(barsSinceHighAbove) and barsSinceHighAbove >= 1 and barsSinceHighAbove <= contactLookback and close < vwapSrc

vwapContactBuy  = buyContactNow  or priorBuyContact
vwapContactSell = sellContactNow or priorSellContact

// ─────────────────────────────────────────────────────────────────────────────
// 8. Signal detection
// ─────────────────────────────────────────────────────────────────────────────

isSignalBarBuy  = vwapUp   and vwapContactBuy  and isBullSig
isSignalBarSell = vwapDown and vwapContactSell and isBearSig

confirmed = barstate.isconfirmed

// ─────────────────────────────────────────────────────────────────────────────
// 9. Risk / Entry / State machine
// ─────────────────────────────────────────────────────────────────────────────

// 状态: 0 = flat（无信号）, 1 = armed long（多头挂单等待）, -1 = armed short
//       挂单触发后 isFilled := true，仍保留 positionState 直到 SL / TP 命中
var int   positionState = 0
var int   signalBarIdx  = na
var float entryPrice    = na
var float slPrice       = na
var float tp1Price      = na
var float tp2Price      = na
var bool  isFilled      = false

// 仅 confirmed bar 触发新信号；要求当前为 flat 状态
buySig  = confirmed and isSignalBarBuy  and positionState == 0
sellSig = confirmed and isSignalBarSell and positionState == 0

// Stop 计算源
swingBuyStop  = ta.lowest (low,  swingLook)
swingSellStop = ta.highest(high, swingLook)

if buySig
    positionState := 1
    signalBarIdx  := bar_index
    entryPrice    := high + syminfo.mintick
    slPrice       := stopMode == "Signal Bar" ? low - syminfo.mintick
                                              : math.min(low, swingBuyStop) - syminfo.mintick
    float riskR   = entryPrice - slPrice
    tp1Price      := entryPrice + riskR * tpRrR1
    tp2Price      := entryPrice + riskR * tpRrR2
    isFilled      := false

if sellSig
    positionState := -1
    signalBarIdx  := bar_index
    entryPrice    := low - syminfo.mintick
    slPrice       := stopMode == "Signal Bar" ? high + syminfo.mintick
                                              : math.max(high, swingSellStop) + syminfo.mintick
    float riskR   = slPrice - entryPrice
    tp1Price      := entryPrice - riskR * tpRrR1
    tp2Price      := entryPrice - riskR * tpRrR2
    isFilled      := false

// 触发 / 出场 / 撤单管理（仅在信号 K 之后的 K 线生效）
canManage = positionState != 0 and not na(signalBarIdx) and bar_index > signalBarIdx

// 9.1 挂单触发（突破信号 K 高 / 低）
if canManage and not isFilled
    if positionState == 1 and high >= entryPrice
        isFilled := true
    if positionState == -1 and low <= entryPrice
        isFilled := true

// 9.2 已触发：检查 SL / TP2 命中后退出
if canManage and isFilled
    if positionState == 1 and (low <= slPrice or high >= tp2Price)
        positionState := 0
        signalBarIdx  := na
        entryPrice    := na
        slPrice       := na
        tp1Price      := na
        tp2Price      := na
        isFilled      := false
    if positionState == -1 and (high >= slPrice or low <= tp2Price)
        positionState := 0
        signalBarIdx  := na
        entryPrice    := na
        slPrice       := na
        tp1Price      := na
        tp2Price      := na
        isFilled      := false

// 9.3 未触发 + 超时 → 撤单
barsSinceSignal = na(signalBarIdx) ? na : bar_index - signalBarIdx
shouldCancel    = positionState != 0 and not isFilled and not na(barsSinceSignal) and barsSinceSignal >= lockTimeout
if shouldCancel
    positionState := 0
    signalBarIdx  := na
    entryPrice    := na
    slPrice       := na
    tp1Price      := na
    tp2Price      := na
    isFilled      := false

// 9.4 反向信号解锁（避免方向已反转仍被旧信号锁住）
reverseUnlockLong  = positionState ==  1 and isSignalBarSell
reverseUnlockShort = positionState == -1 and isSignalBarBuy
reverseUnlock      = confirmed and (reverseUnlockLong or reverseUnlockShort)
if reverseUnlock
    positionState := 0
    signalBarIdx  := na
    entryPrice    := na
    slPrice       := na
    tp1Price      := na
    tp2Price      := na
    isFilled      := false

// ─────────────────────────────────────────────────────────────────────────────
// 10. Visualization
// ─────────────────────────────────────────────────────────────────────────────

var label[] sigLabels = array.new<label>()
var box[]   slBoxes   = array.new<box>()
var box[]   tp1Boxes  = array.new<box>()
var box[]   tp2Boxes  = array.new<box>()

f_pushLabel(_lb) =>
    array.push(sigLabels, _lb)
    if array.size(sigLabels) > maxSignals * 2
        label.delete(array.shift(sigLabels))

f_pushSlBox(_bx) =>
    array.push(slBoxes, _bx)
    if array.size(slBoxes) > maxSignals
        box.delete(array.shift(slBoxes))

f_pushTp1Box(_bx) =>
    array.push(tp1Boxes, _bx)
    if array.size(tp1Boxes) > maxSignals
        box.delete(array.shift(tp1Boxes))

f_pushTp2Box(_bx) =>
    array.push(tp2Boxes, _bx)
    if array.size(tp2Boxes) > maxSignals
        box.delete(array.shift(tp2Boxes))

// 多头 setup 画图
if buySig
    // 箭头标记
    f_pushLabel(label.new(bar_index, low, f_bullChar(shapeOpt),
                          style=label.style_none, textcolor=bullCol,
                          size=f_size(sizeOpt), yloc=yloc.belowbar))

    // SL 框：top = entryPrice, bottom = slPrice
    if showSL and not na(entryPrice) and not na(slPrice)
        f_pushSlBox(box.new(bar_index, entryPrice, bar_index + boxWidth, slPrice,
                            bgcolor=slBoxColor,
                            border_color=color.new(color.red, borderTrans),
                            border_width=1))

    // TP1 框：top = tp1Price, bottom = entryPrice
    if showTP and not na(tp1Price) and not na(entryPrice)
        f_pushTp1Box(box.new(bar_index, tp1Price, bar_index + boxWidth, entryPrice,
                             bgcolor=tp1BoxColor,
                             border_color=color.new(color.teal, borderTrans),
                             border_width=1))

    // TP2 框：top = tp2Price, bottom = tp1Price
    if showTP and not na(tp2Price) and not na(tp1Price)
        f_pushTp2Box(box.new(bar_index, tp2Price, bar_index + boxWidth, tp1Price,
                             bgcolor=tp2BoxColor,
                             border_color=color.new(color.teal, borderTrans),
                             border_width=1))

// 空头 setup 画图
if sellSig
    f_pushLabel(label.new(bar_index, high, f_bearChar(shapeOpt),
                          style=label.style_none, textcolor=bearCol,
                          size=f_size(sizeOpt), yloc=yloc.abovebar))

    // SL 框：top = slPrice, bottom = entryPrice
    if showSL and not na(slPrice) and not na(entryPrice)
        f_pushSlBox(box.new(bar_index, slPrice, bar_index + boxWidth, entryPrice,
                            bgcolor=slBoxColor,
                            border_color=color.new(color.red, borderTrans),
                            border_width=1))

    // TP1 框：top = entryPrice, bottom = tp1Price
    if showTP and not na(entryPrice) and not na(tp1Price)
        f_pushTp1Box(box.new(bar_index, entryPrice, bar_index + boxWidth, tp1Price,
                             bgcolor=tp1BoxColor,
                             border_color=color.new(color.teal, borderTrans),
                             border_width=1))

    // TP2 框：top = tp1Price, bottom = tp2Price
    if showTP and not na(tp1Price) and not na(tp2Price)
        f_pushTp2Box(box.new(bar_index, tp1Price, bar_index + boxWidth, tp2Price,
                             bgcolor=tp2BoxColor,
                             border_color=color.new(color.teal, borderTrans),
                             border_width=1))

// ─────────────────────────────────────────────────────────────────────────────
// 11. Alert conditions
// ─────────────────────────────────────────────────────────────────────────────

alertcondition(buySig,  title="VWAP PA Buy Setup",
     message="VWAP PA Brooks: BUY setup detected — place Buy Stop @ signal high + 1 tick on next bar")
alertcondition(sellSig, title="VWAP PA Sell Setup",
     message="VWAP PA Brooks: SELL setup detected — place Sell Stop @ signal low - 1 tick on next bar")

buyFilled  = confirmed and positionState ==  1 and isFilled and not nz(isFilled[1], false)
sellFilled = confirmed and positionState == -1 and isFilled and not nz(isFilled[1], false)
alertcondition(buyFilled,  title="VWAP PA Buy Filled",
     message="VWAP PA Brooks: Buy Stop FILLED")
alertcondition(sellFilled, title="VWAP PA Sell Filled",
     message="VWAP PA Brooks: Sell Stop FILLED")

// ─────────────────────────────────────────────────────────────────────────────
// 12. Info panel
// ─────────────────────────────────────────────────────────────────────────────

f_stateText() =>
    s = "?"
    if positionState == 0
        s := "FLAT / Waiting"
    if positionState == 1
        s := isFilled ? "LONG Filled"  : "Long Armed (waiting fill)"
    if positionState == -1
        s := isFilled ? "SHORT Filled" : "Short Armed (waiting fill)"
    s

f_stateColor() =>
    c = color.new(color.gray, 30)
    if positionState == 1
        c := color.new(color.green, 30)
    if positionState == -1
        c := color.new(color.red, 30)
    c

f_trendText() =>
    vwapUp ? "VWAP Up" : vwapDown ? "VWAP Down" : "VWAP Flat / Filtered"

stateText  = f_stateText()
stateColor = f_stateColor()
trendText  = f_trendText()

var table panel = table.new(position.top_right, 2, 3, border_width=1)
if showPanel and barstate.islast
    table.cell(panel, 0, 0, "Trend", text_color=color.white, bgcolor=color.new(color.gray, 50))
    table.cell(panel, 1, 0, trendText, text_color=color.white, bgcolor=color.new(color.gray, 30))
    table.cell(panel, 0, 1, "State", text_color=color.white, bgcolor=color.new(color.gray, 50))
    table.cell(panel, 1, 1, stateText, text_color=color.white, bgcolor=stateColor)
    table.cell(panel, 0, 2, "Slope/ATR", text_color=color.white, bgcolor=color.new(color.gray, 50))
    table.cell(panel, 1, 2, str.tostring(vwapSlopeRaw, "#.###"),
               text_color=color.white, bgcolor=color.new(color.gray, 30))
