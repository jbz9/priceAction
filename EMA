//@version=5
indicator("EMA PA - Brooks", overlay=true, max_labels_count=500, max_lines_count=500)

f_ma(src, len, type) =>
    switch type
        "SMA" => ta.sma(src, len)
        "EMA" => ta.ema(src, len)
        "WMA" => ta.wma(src, len)
        "RMA" => ta.rma(src, len)
        => ta.ema(src, len)

gr0 = "Pullback Logic"
pbLookback  = input.int(10,    "回调回溯周期",          minval=2, group=gr0)
slopeFilter = input.bool(true, "均线斜率过滤",                    group=gr0)
strictPA    = input.bool(true, "严格 K 线质量过滤",               group=gr0)
maxSignals  = input.int(3,     "最近显示信号组数",       minval=1, group=gr0)

gr1 = "Moving Average Settings"
maType  = input.string("EMA", "MA Type", options=["SMA","EMA","WMA","RMA"], group=gr1)
emaLen  = input.int(21, "MA 1 (Signal Line)", minval=1, group=gr1)
emaLen1 = input.int(49, "MA 2 (Trend Line)",  minval=1, group=gr1)

ema1 = f_ma(close, emaLen,  maType)
ema2 = f_ma(close, emaLen1, maType)
plot(ema1, "MA 1 (Signal Line)", color=color.black, linewidth=1, display=display.none)
plot(ema2, "MA 2 (Trend Line)",  color=color.red,   linewidth=1, display=display.none)

grMC = "Market Cycle Filter"
useMarketCycleFilter = input.bool(true,  "启用市场周期过滤",        group=grMC)
atrLen      = input.int(14,              "ATR Length",    minval=1,  group=grMC)
minSepAtr   = input.float(0.15,          "最小均线分离度 ATR 倍数",  step=0.05, group=grMC)
rangeLen    = input.int(20,              "区间检测周期",  minval=5,  group=grMC)
minRangeAtr = input.float(1.20,          "最小区间高度 ATR 倍数",    step=0.10, group=grMC)
midLow      = input.float(0.35,          "区间中部下界",             step=0.05, group=grMC)
midHigh     = input.float(0.65,          "区间中部上界",             step=0.05, group=grMC)
showContext = input.bool(true,           "显示市场状态标签",         group=grMC)

atr = ta.atr(atrLen)
emaSpreadOk     = math.abs(ema1 - ema2) > atr * minSepAtr
recentHigh      = ta.highest(high, rangeLen)
recentLow       = ta.lowest(low,   rangeLen)
recentRange     = recentHigh - recentLow
rangeWideEnough = recentRange > atr * minRangeAtr
pricePosInRange = recentRange > 0 ? (close - recentLow) / recentRange : 0.5
isRangeMiddle   = pricePosInRange >= midLow and pricePosInRange <= midHigh
avoidNarrowMiddle = not (not rangeWideEnough and isRangeMiddle)
marketCycleOk   = useMarketCycleFilter ? (emaSpreadOk and avoidNarrowMiddle) : true

marketState = not useMarketCycleFilter   ? "Filter OFF" :
              not emaSpreadOk            ? "EMA Chop / TR Risk" :
              not avoidNarrowMiddle      ? "Narrow TR Middle" :
                                           "Trend / Pullback OK"

var table contextTable = table.new(position.top_right, 1, 1)
if showContext and barstate.islast
    table.cell(contextTable, 0, 0, marketState,
               text_color=color.white,
               bgcolor=marketCycleOk ? color.new(color.green, 30) : color.new(color.red, 30))

barRange   = high - low
bodySize   = math.abs(close - open)
upperTail  = high - math.max(close, open)
lowerTail  = math.min(close, open) - low
midPoint   = (high + low) / 2
validRange = barRange > syminfo.mintick

qualityBullSignal = validRange and bodySize > barRange * 0.5 and upperTail < bodySize and close > midPoint
qualityBearSignal = validRange and bodySize > barRange * 0.5 and lowerTail < bodySize and close < midPoint
isBullSignalBar = strictPA ? (close > open and qualityBullSignal) : (close > open)
isBearSignalBar = strictPA ? (close < open and qualityBearSignal) : (close < open)

qualityBullEntry = validRange and bodySize > barRange * 0.4 and upperTail < bodySize * 1.5 and close > midPoint
qualityBearEntry = validRange and bodySize > barRange * 0.4 and lowerTail < bodySize * 1.5 and close < midPoint
isBullEntry = strictPA ? (close > open and qualityBullEntry) : (close > open)
isBearEntry = strictPA ? (close < open and qualityBearEntry) : (close < open)

emaUp   = slopeFilter ? ema1 > ema1[1] : true
emaDown = slopeFilter ? ema1 < ema1[1] : true

barsSinceBelow = ta.barssince(low  <= ema1)
barsSinceAbove = ta.barssince(high >= ema1)

emaInteractionBuy  = low  <= ema1 and close > ema1
emaInteractionSell = high >= ema1 and close < ema1

priorTouchBuy  = not na(barsSinceBelow) and barsSinceBelow >= 1 and barsSinceBelow <= pbLookback
priorTouchSell = not na(barsSinceAbove) and barsSinceAbove >= 1 and barsSinceAbove <= pbLookback

emaContactBuy  = emaInteractionBuy  or (priorTouchBuy  and close > ema1)
emaContactSell = emaInteractionSell or (priorTouchSell and close < ema1)

isSignalBarBuy  = marketCycleOk and (ema1 > ema2) and emaUp   and emaContactBuy  and isBullSignalBar
isSignalBarSell = marketCycleOk and (ema1 < ema2) and emaDown and emaContactSell and isBearSignalBar

confirmed  = barstate.isconfirmed
buySignal  = confirmed and isSignalBarBuy[1]  and close > high[1] and isBullEntry
sellSignal = confirmed and isSignalBarSell[1] and close < low[1]  and isBearEntry

// ══════════════════════════════════════════════════════════════════════════════
// 10. 止损逻辑 ✅ 新增 showSL 开关
// ══════════════════════════════════════════════════════════════════════════════
grSL = "Stop Loss"
stopMode          = input.string("Signal Bar", "Stop Mode", options=["Signal Bar","Entry Bar","Swing Pivot"], group=grSL)
swingStopLookback = input.int(5, "Swing Pivot Lookback", minval=2, group=grSL)
showSL            = input.bool(true, "显示止损线", group=grSL)  // ✅ 新增

swingBuyStop  = ta.lowest(low,   swingStopLookback)
swingSellStop = ta.highest(high, swingStopLookback)

buySLPrice  = stopMode == "Signal Bar" ? low[1]  : stopMode == "Entry Bar" ? low  : swingBuyStop
sellSLPrice = stopMode == "Signal Bar" ? high[1] : stopMode == "Entry Bar" ? high : swingSellStop

var float activeBuySL    = na
var float activeSellSL   = na
var int   activeBuySLBar = na
var int   activeSellSLBar= na
var line  buySLLine      = na
var line  sellSLLine     = na

grTP    = "Take Profit Levels (Latest Signal Only)"
showTP  = input.bool(true,  "显示止盈线",                                   group=grTP)
tp1Col  = input.color(color.new(color.teal, 0), "1R 颜色",                  group=grTP)
tp2Col  = input.color(color.new(color.blue, 0), "2R 颜色",                  group=grTP)
tpWidth = input.int(2,      "线条宽度",   minval=1, maxval=4,               group=grTP)
tpStyle = input.string("Solid", "线条样式", options=["Solid","Dashed","Dotted"], group=grTP)

f_tpStyle(s) =>
    switch s
        "Solid"  => line.style_solid
        "Dashed" => line.style_dashed
        "Dotted" => line.style_dotted
        =>          line.style_dashed

var float activeBuyTP1  = na
var float activeBuyTP2  = na
var float activeSellTP1 = na
var float activeSellTP2 = na
var line  buyTP1Line    = na
var line  buyTP2Line    = na
var line  sellTP1Line   = na
var line  sellTP2Line   = na
var label buyTP1Label   = na
var label buyTP2Label   = na
var label sellTP1Label  = na
var label sellTP2Label  = na

f_deleteTPLine(ln) =>
    if not na(ln)
        line.delete(ln)

f_deleteTPLabel(lb) =>
    if not na(lb)
        label.delete(lb)

// ══════════════════════════════════════════════════════════════════════════════
// 12. 信号触发 ✅ 止损线创建改为条件创建
// ══════════════════════════════════════════════════════════════════════════════
if buySignal
    activeBuySL    := buySLPrice
    activeBuySLBar := bar_index
    activeSellSL   := na
    activeSellSLBar:= na
    // ✅ showSL 控制是否创建线条，na 时延伸逻辑自动跳过
    buySLLine := showSL ? line.new(bar_index, activeBuySL, bar_index + 1, activeBuySL, color=color.red, width=1) : na

    if showTP
        f_deleteTPLine(buyTP1Line)
        f_deleteTPLine(buyTP2Line)
        f_deleteTPLine(sellTP1Line)
        f_deleteTPLine(sellTP2Line)
        f_deleteTPLabel(buyTP1Label)
        f_deleteTPLabel(buyTP2Label)
        f_deleteTPLabel(sellTP1Label)
        f_deleteTPLabel(sellTP2Label)
        activeBuyTP1  := na
        activeBuyTP2  := na
        activeSellTP1 := na
        activeSellTP2 := na
        buyTP1Line    := na
        buyTP2Line    := na
        sellTP1Line   := na
        sellTP2Line   := na
        buyTP1Label   := na
        buyTP2Label   := na
        sellTP1Label  := na
        sellTP2Label  := na

        float entryBuy = high[1]
        float riskBuy  = entryBuy - buySLPrice

        activeBuyTP1 := entryBuy + riskBuy
        activeBuyTP2 := entryBuy + riskBuy * 2.0

        buyTP1Line  := line.new(bar_index, activeBuyTP1, bar_index + 1, activeBuyTP1,
                                 color=tp1Col, width=tpWidth, style=f_tpStyle(tpStyle))
        buyTP2Line  := line.new(bar_index, activeBuyTP2, bar_index + 1, activeBuyTP2,
                                 color=tp2Col, width=tpWidth, style=f_tpStyle(tpStyle))
        buyTP1Label := label.new(bar_index, activeBuyTP1, "1R",
                                  style=label.style_none, textcolor=tp1Col,
                                  size=size.small, yloc=yloc.price)
        buyTP2Label := label.new(bar_index, activeBuyTP2, "2R",
                                  style=label.style_none, textcolor=tp2Col,
                                  size=size.small, yloc=yloc.price)

if sellSignal
    activeSellSL   := sellSLPrice
    activeSellSLBar:= bar_index
    activeBuySL    := na
    activeBuySLBar := na
    // ✅ showSL 控制是否创建线条
    sellSLLine := showSL ? line.new(bar_index, activeSellSL, bar_index + 1, activeSellSL, color=color.red, width=1) : na

    if showTP
        f_deleteTPLine(buyTP1Line)
        f_deleteTPLine(buyTP2Line)
        f_deleteTPLine(sellTP1Line)
        f_deleteTPLine(sellTP2Line)
        f_deleteTPLabel(buyTP1Label)
        f_deleteTPLabel(buyTP2Label)
        f_deleteTPLabel(sellTP1Label)
        f_deleteTPLabel(sellTP2Label)
        activeBuyTP1  := na
        activeBuyTP2  := na
        activeSellTP1 := na
        activeSellTP2 := na
        buyTP1Line    := na
        buyTP2Line    := na
        sellTP1Line   := na
        sellTP2Line   := na
        buyTP1Label   := na
        buyTP2Label   := na
        sellTP1Label  := na
        sellTP2Label  := na

        float entrySell = low[1]
        float riskSell  = sellSLPrice - entrySell

        activeSellTP1 := entrySell - riskSell
        activeSellTP2 := entrySell - riskSell * 2.0

        sellTP1Line  := line.new(bar_index, activeSellTP1, bar_index + 1, activeSellTP1,
                                  color=tp1Col, width=tpWidth, style=f_tpStyle(tpStyle))
        sellTP2Line  := line.new(bar_index, activeSellTP2, bar_index + 1, activeSellTP2,
                                  color=tp2Col, width=tpWidth, style=f_tpStyle(tpStyle))
        sellTP1Label := label.new(bar_index, activeSellTP1, "1R",
                                   style=label.style_none, textcolor=tp1Col,
                                   size=size.small, yloc=yloc.price)
        sellTP2Label := label.new(bar_index, activeSellTP2, "2R",
                                   style=label.style_none, textcolor=tp2Col,
                                   size=size.small, yloc=yloc.price)

if not na(activeBuySL)  and not na(buySLLine)
    line.set_x2(buySLLine,  bar_index)
if not na(activeSellSL) and not na(sellSLLine)
    line.set_x2(sellSLLine, bar_index)

if showTP
    if not na(activeBuyTP1)  and not na(buyTP1Line)
        line.set_x2(buyTP1Line,  bar_index)
    if not na(activeBuyTP2)  and not na(buyTP2Line)
        line.set_x2(buyTP2Line,  bar_index)
    if not na(activeSellTP1) and not na(sellTP1Line)
        line.set_x2(sellTP1Line, bar_index)
    if not na(activeSellTP2) and not na(sellTP2Line)
        line.set_x2(sellTP2Line, bar_index)

buyStopCanTrigger  = not na(activeBuySLBar)  and bar_index > activeBuySLBar
sellStopCanTrigger = not na(activeSellSLBar) and bar_index > activeSellSLBar

if buyStopCanTrigger and not na(activeBuySL) and low <= activeBuySL
    activeBuySL    := na
    activeBuySLBar := na
    if showTP
        f_deleteTPLine(buyTP1Line)
        f_deleteTPLine(buyTP2Line)
        f_deleteTPLine(sellTP1Line)
        f_deleteTPLine(sellTP2Line)
        f_deleteTPLabel(buyTP1Label)
        f_deleteTPLabel(buyTP2Label)
        f_deleteTPLabel(sellTP1Label)
        f_deleteTPLabel(sellTP2Label)
        activeBuyTP1  := na
        activeBuyTP2  := na
        activeSellTP1 := na
        activeSellTP2 := na
        buyTP1Line    := na
        buyTP2Line    := na
        sellTP1Line   := na
        sellTP2Line   := na
        buyTP1Label   := na
        buyTP2Label   := na
        sellTP1Label  := na
        sellTP2Label  := na

if sellStopCanTrigger and not na(activeSellSL) and high >= activeSellSL
    activeSellSL   := na
    activeSellSLBar:= na
    if showTP
        f_deleteTPLine(buyTP1Line)
        f_deleteTPLine(buyTP2Line)
        f_deleteTPLine(sellTP1Line)
        f_deleteTPLine(sellTP2Line)
        f_deleteTPLabel(buyTP1Label)
        f_deleteTPLabel(buyTP2Label)
        f_deleteTPLabel(sellTP1Label)
        f_deleteTPLabel(sellTP2Label)
        activeBuyTP1  := na
        activeBuyTP2  := na
        activeSellTP1 := na
        activeSellTP2 := na
        buyTP1Line    := na
        buyTP2Line    := na
        sellTP1Line   := na
        sellTP2Line   := na
        buyTP1Label   := na
        buyTP2Label   := na
        sellTP1Label  := na
        sellTP2Label  := na

grStyle  = "Signal Styling"
shapeOpt = input.string("圆形", "信号形状", options=["圆形","正方形","菱形","十字"], group=grStyle)
sizeOpt  = input.string("中",   "图形大小", options=["小","中","大","巨大"],         group=grStyle)
bullCol  = input.color(color.green, "Buy Color",  group=grStyle)
bearCol  = input.color(color.red,   "Sell Color", group=grStyle)

get_char(opt) =>
    switch opt
        "圆形"   => "●"
        "正方形" => "■"
        "菱形"   => "◆"
        "十字"   => "✚"
        => "●"

get_size(opt) =>
    switch opt
        "小"   => size.small
        "中"   => size.normal
        "大"   => size.large
        "巨大" => size.huge
        => size.small

var label[] allLabels = array.new_label()
var line[]  allLines  = array.new_line()

f_addLabel(lbl) =>
    array.push(allLabels, lbl)
    if array.size(allLabels) > maxSignals * 2
        label.delete(array.shift(allLabels))

f_addLine(ln) =>
    array.push(allLines, ln)
    if array.size(allLines) > maxSignals
        line.delete(array.shift(allLines))

// ══════════════════════════════════════════════════════════════════════════════
// 16. 对象绘制 ✅ Stop 标签和 f_addLine 加 showSL 条件
// ══════════════════════════════════════════════════════════════════════════════
if buySignal
    f_addLabel(label.new(bar_index, low,  get_char(shapeOpt), style=label.style_none, textcolor=bullCol, size=get_size(sizeOpt), yloc=yloc.belowbar))
    if showSL  // ✅ 仅在 showSL 开启时添加 Stop 标签和止损线
        f_addLabel(label.new(bar_index, activeBuySL, "Stop", style=label.style_none, textcolor=color.red, size=size.small, yloc=yloc.price))
        f_addLine(buySLLine)

if sellSignal
    f_addLabel(label.new(bar_index, high, get_char(shapeOpt), style=label.style_none, textcolor=bearCol, size=get_size(sizeOpt), yloc=yloc.abovebar))
    if showSL  // ✅ 仅在 showSL 开启时添加 Stop 标签和止损线
        f_addLabel(label.new(bar_index, activeSellSL, "Stop", style=label.style_none, textcolor=color.red, size=size.small, yloc=yloc.price))
        f_addLine(sellSLLine)

alertcondition(buySignal,  "Brooks PA Buy",  "Brooks PA Buy Signal")
alertcondition(sellSignal, "Brooks PA Sell", "Brooks PA Sell Signal")
