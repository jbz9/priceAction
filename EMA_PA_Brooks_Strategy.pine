//@version=5
// v1.2 策略回测版（2025-05）
// 完全基于 EMA_PA_Brooks.pine 最新版信号逻辑
// 入场：信号 K 收盘后，下一根 bar 挂 buy stop @ signal bar high + 1 tick
//       或 sell stop @ signal bar low - 1 tick
// 止损：Signal Bar（信号 K 的 low/high）
// 止盈：2R（整仓）
// 仓位：$1000 本金，单笔 5% 风险
strategy("EMA PA - Brooks [Strategy]",
      overlay=true,
      initial_capital=1000,
      default_qty_type=strategy.fixed,
      default_qty_value=1,
      commission_type=strategy.commission.cash_per_order,
      commission_value=0,
      slippage=1,
      pyramiding=0,
      process_orders_on_close=false,
      max_labels_count=500,
      max_lines_count=500)

// ══════════════════════════════════════════════════════════════════════════════
// Helper
// ══════════════════════════════════════════════════════════════════════════════
f_ma(src, len, type) =>
    switch type
        "SMA" => ta.sma(src, len)
        "EMA" => ta.ema(src, len)
        "WMA" => ta.wma(src, len)
        "RMA" => ta.rma(src, len)
        => ta.ema(src, len)

// ══════════════════════════════════════════════════════════════════════════════
// Inputs（与 indicator 完全一致）
// ══════════════════════════════════════════════════════════════════════════════
gr0 = "Pullback Logic"
pbLookback  = input.int(10,    "回调回溯周期",          minval=2, group=gr0)
slopeFilter = input.bool(true, "均线斜率过滤",                    group=gr0)
strictPA    = input.bool(true, "严格 K 线质量过滤",               group=gr0)
lockTimeout = input.int(30,    "信号锁超时(K线数)",      minval=5, group=gr0, tooltip="持仓后超过N根K线未触发SL/TP则自动平仓")

gr1 = "Moving Average Settings"
maType  = input.string("EMA", "MA Type", options=["SMA","EMA","WMA","RMA"], group=gr1)
emaLen  = input.int(21, "MA 1 (Signal Line)", minval=1, group=gr1)
emaLen1 = input.int(49, "MA 2 (Trend Line)",  minval=1, group=gr1)

grMC = "Market Cycle Filter"
useMarketCycleFilter = input.bool(true,  "启用市场周期过滤",        group=grMC)
atrLen      = input.int(14,              "ATR Length",    minval=1,  group=grMC)
minSepAtr   = input.float(0.15,          "最小均线分离度 ATR 倍数",  step=0.05, group=grMC)
rangeLen    = input.int(20,              "区间检测周期",  minval=5,  group=grMC)
minRangeAtr = input.float(1.20,          "最小区间高度 ATR 倍数",    step=0.10, group=grMC)
midLow      = input.float(0.35,          "区间中部下界",             step=0.05, group=grMC)
midHigh     = input.float(0.65,          "区间中部上界",             step=0.05, group=grMC)

grSL = "Stop Loss"
stopMode          = input.string("Signal Bar", "Stop Mode", options=["Signal Bar","Entry Bar","Swing Pivot"], group=grSL)
swingStopLookback = input.int(5, "Swing Pivot Lookback", minval=2, group=grSL)

grRisk = "Risk Management"
riskPct = input.float(5.0, "单笔风险 %", minval=0.5, maxval=20.0, step=0.5, group=grRisk, tooltip="每笔交易最大亏损占当前权益的百分比")

// ══════════════════════════════════════════════════════════════════════════════
// Moving Averages
// ══════════════════════════════════════════════════════════════════════════════
ema1 = f_ma(close, emaLen,  maType)
ema2 = f_ma(close, emaLen1, maType)
plot(ema1, "MA 1 (Signal Line)", color=color.black, linewidth=1)
plot(ema2, "MA 2 (Trend Line)",  color=color.red,   linewidth=1)

// ══════════════════════════════════════════════════════════════════════════════
// Market Cycle Filter（与 indicator 完全一致）
// ══════════════════════════════════════════════════════════════════════════════
atr = ta.atr(atrLen)
emaSpreadOk     = math.abs(ema1 - ema2) > atr * minSepAtr
recentHigh      = ta.highest(high, rangeLen)
recentLow       = ta.lowest(low,   rangeLen)
recentRange     = recentHigh - recentLow
rangeWideEnough = recentRange > atr * minRangeAtr
pricePosInRange = recentRange > 0 ? (close - recentLow) / recentRange : 0.5
isRangeMiddle   = pricePosInRange >= midLow and pricePosInRange <= midHigh
avoidNarrowMiddle = not (not rangeWideEnough and isRangeMiddle)
marketCycleOk   = useMarketCycleFilter ? (emaSpreadOk and avoidNarrowMiddle) : true

// ══════════════════════════════════════════════════════════════════════════════
// Bar Quality（与 indicator 完全一致）
// ══════════════════════════════════════════════════════════════════════════════
barRange   = high - low
bodySize   = math.abs(close - open)
upperTail  = high - math.max(close, open)
lowerTail  = math.min(close, open) - low
midPoint   = (high + low) / 2
validRange = barRange > syminfo.mintick

qualityBullSignal = validRange and bodySize > barRange * 0.5 and upperTail < bodySize and close > midPoint
qualityBearSignal = validRange and bodySize > barRange * 0.5 and lowerTail < bodySize and close < midPoint
isBullSignalBar = strictPA ? (close > open and qualityBullSignal) : (close > open)
isBearSignalBar = strictPA ? (close < open and qualityBearSignal) : (close < open)

qualityBullEntry = validRange and bodySize > barRange * 0.4 and upperTail < bodySize * 1.5 and close > midPoint
qualityBearEntry = validRange and bodySize > barRange * 0.4 and lowerTail < bodySize * 1.5 and close < midPoint
isBullEntry = strictPA ? (close > open and qualityBullEntry) : (close > open)
isBearEntry = strictPA ? (close < open and qualityBearEntry) : (close < open)

// ══════════════════════════════════════════════════════════════════════════════
// EMA Slope & Contact（与 indicator 完全一致）
// ══════════════════════════════════════════════════════════════════════════════
emaUp   = slopeFilter ? ema1 > ema1[1] : true
emaDown = slopeFilter ? ema1 < ema1[1] : true

barsSinceBelow = ta.barssince(low  <= ema1)
barsSinceAbove = ta.barssince(high >= ema1)

emaInteractionBuy  = low  <= ema1 and close > ema1
emaInteractionSell = high >= ema1 and close < ema1

priorTouchBuy  = not na(barsSinceBelow) and barsSinceBelow >= 1 and barsSinceBelow <= pbLookback
priorTouchSell = not na(barsSinceAbove) and barsSinceAbove >= 1 and barsSinceAbove <= pbLookback

emaContactBuy  = emaInteractionBuy  or (priorTouchBuy  and close > ema1)
emaContactSell = emaInteractionSell or (priorTouchSell and close < ema1)

// ══════════════════════════════════════════════════════════════════════════════
// Signal Detection（与 indicator 完全一致）
// ══════════════════════════════════════════════════════════════════════════════
isSignalBarBuy  = marketCycleOk and (ema1 > ema2) and emaUp   and emaContactBuy  and isBullSignalBar
isSignalBarSell = marketCycleOk and (ema1 < ema2) and emaDown and emaContactSell and isBearSignalBar

confirmed = barstate.isconfirmed

// indicator 中的 buySignalRaw/sellSignalRaw 用于"跟随 K 确认"显示
// strategy 中我们不需要跟随 K 确认，而是直接在信号 K 收盘后挂 stop order
// 信号 K 本身的条件就是入场触发条件

// ══════════════════════════════════════════════════════════════════════════════
// Stop Loss Price（与 indicator 完全一致的三种模式）
// ══════════════════════════════════════════════════════════════════════════════
swingBuyStop  = ta.lowest(low,   swingStopLookback)
swingSellStop = ta.highest(high, swingStopLookback)

// ══════════════════════════════════════════════════════════════════════════════
// Strategy Execution
//
// Brooks 入场时序：
//   Bar N: 信号 K 收盘 → 满足 isSignalBarBuy/Sell 所有条件
//   Bar N+1: 挂 buy stop @ Bar N high + 1 tick（或 sell stop @ Bar N low - 1 tick）
//            如果 Bar N+1 触及该价格 → 成交
//            如果 Bar N+1 未触及 → 下一根 bar 取消（1 bar timeout）
//
// 止损：Signal Bar 模式 = 信号 K 的 low（做多）/ high（做空）
//       Entry Bar 模式 = 入场 bar 的 low/high（需成交后才知道，此处近似用信号 K）
//       Swing Pivot 模式 = 最近 N 根的最低/最高
// 止盈：2R
// ══════════════════════════════════════════════════════════════════════════════
noPosition = strategy.position_size == 0

// 状态变量：记录挂单信息
var bool  hasPendingBuy    = false
var bool  hasPendingSell   = false
var float pendingBuyEntry  = na
var float pendingBuySL     = na
var float pendingBuyTP     = na
var float pendingBuyQty    = na
var float pendingSellEntry = na
var float pendingSellSL    = na
var float pendingSellTP    = na
var float pendingSellQty   = na
var int   pendingBarIdx    = na

// 信号 K 收盘确认 → 准备下一根 bar 的挂单
if confirmed and isSignalBarBuy and noPosition
    float entry = high + syminfo.mintick
    float sl = stopMode == "Signal Bar" ? low : stopMode == "Entry Bar" ? low : swingBuyStop
    float risk = entry - sl
    float tp = entry + risk * 2.0
    float riskMoney = strategy.equity * riskPct / 100.0
    float qty = risk > 0 ? math.floor(riskMoney / risk * 100) / 100 : 0.0
    if qty > 0 and risk > 0
        hasPendingBuy    := true
        hasPendingSell   := false
        pendingBuyEntry  := entry
        pendingBuySL     := sl
        pendingBuyTP     := tp
        pendingBuyQty    := qty
        pendingBarIdx    := bar_index
        // 取消任何之前的 sell 挂单
        strategy.cancel("Short")
        pendingSellEntry := na
        pendingSellSL    := na
        pendingSellTP    := na
        pendingSellQty   := na

if confirmed and isSignalBarSell and noPosition
    float entry = low - syminfo.mintick
    float sl = stopMode == "Signal Bar" ? high : stopMode == "Entry Bar" ? high : swingSellStop
    float risk = sl - entry
    float tp = entry - risk * 2.0
    float riskMoney = strategy.equity * riskPct / 100.0
    float qty = risk > 0 ? math.floor(riskMoney / risk * 100) / 100 : 0.0
    if qty > 0 and risk > 0
        hasPendingSell   := true
        hasPendingBuy    := false
        pendingSellEntry := entry
        pendingSellSL    := sl
        pendingSellTP    := tp
        pendingSellQty   := qty
        pendingBarIdx    := bar_index
        // 取消任何之前的 buy 挂单
        strategy.cancel("Long")
        pendingBuyEntry  := na
        pendingBuySL     := na
        pendingBuyTP     := na
        pendingBuyQty    := na

// 提交 stop order（每根 bar 持续提交，直到成交或超时取消）
if hasPendingBuy and noPosition
    strategy.entry("Long", strategy.long, qty=pendingBuyQty, stop=pendingBuyEntry)
    strategy.exit("Long Exit", "Long", stop=pendingBuySL, limit=pendingBuyTP)

if hasPendingSell and noPosition
    strategy.entry("Short", strategy.short, qty=pendingSellQty, stop=pendingSellEntry)
    strategy.exit("Short Exit", "Short", stop=pendingSellSL, limit=pendingSellTP)

// 成交后清除挂单状态
if strategy.position_size != 0
    hasPendingBuy    := false
    hasPendingSell   := false
    pendingBuyEntry  := na
    pendingBuySL     := na
    pendingBuyTP     := na
    pendingBuyQty    := na
    pendingSellEntry := na
    pendingSellSL    := na
    pendingSellTP    := na
    pendingSellQty   := na

// 1 bar 超时：信号 K 之后只给 1 根 bar 机会突破
if confirmed and noPosition and not na(pendingBarIdx)
    if bar_index - pendingBarIdx >= 1
        if hasPendingBuy
            strategy.cancel("Long")
            hasPendingBuy   := false
            pendingBuyEntry := na
            pendingBuySL    := na
            pendingBuyTP    := na
            pendingBuyQty   := na
        if hasPendingSell
            strategy.cancel("Short")
            hasPendingSell   := false
            pendingSellEntry := na
            pendingSellSL    := na
            pendingSellTP    := na
            pendingSellQty   := na
        pendingBarIdx := na

// lockTimeout：持仓超过 N 根 bar 强制平仓（与 indicator 的 positionState 超时一致）
var int entryBarIdx = na
if strategy.position_size != 0 and strategy.position_size[1] == 0
    entryBarIdx := bar_index

if strategy.position_size != 0 and not na(entryBarIdx)
    if bar_index - entryBarIdx >= lockTimeout
        strategy.close_all("Timeout")
        entryBarIdx := na

if strategy.position_size == 0
    entryBarIdx := na

// ══════════════════════════════════════════════════════════════════════════════
// Visual
// ══════════════════════════════════════════════════════════════════════════════
plotshape(confirmed and isSignalBarBuy  and noPosition, title="Signal Bar Buy",  location=location.belowbar, color=color.green, style=shape.circle, size=size.small)
plotshape(confirmed and isSignalBarSell and noPosition, title="Signal Bar Sell", location=location.abovebar, color=color.red,   style=shape.circle, size=size.small)
