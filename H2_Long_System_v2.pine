// This Pine Script™ source code is subject to the terms of the Mozilla Public License 2.0
// © H2 Long System v2.0 - Based on Al Brooks Price Action
// 基于设计文档 v2.0 的 ES 5分钟 H2 多头交易系统

//@version=5
indicator("H2 Long System v2.0", overlay=true, max_bars_back=500, max_labels_count=50, max_lines_count=50)

// ══════════════════════════════════════════════════════════════════════════════
// 输入参数
// ══════════════════════════════════════════════════════════════════════════════
grp_ind = "指标参数"
emaLen       = input.int(20, "EMA 周期", group=grp_ind)
atrLen       = input.int(14, "ATR 周期", group=grp_ind)
warmupBars   = input.int(50, "Warm-up Bars", group=grp_ind)

grp_trend = "趋势判定"
slopeThresh     = input.float(0.15, "Slope 阈值 (强趋势)", step=0.01, group=grp_trend)
spikeSlope      = input.float(0.30, "Spike Slope 阈值", step=0.01, group=grp_trend)
priceAcceptBars = input.int(12, "价格接受窗口", group=grp_trend)
priceAcceptMin  = input.int(8, "最少 close>EMA 根数", group=grp_trend)

grp_pb = "回调参数"
maxPBRatio1Leg  = input.float(0.50, "单腿最大回调比", step=0.01, group=grp_pb)
maxPBRatio2Leg  = input.float(0.62, "二腿最大回调比", step=0.01, group=grp_pb)
maxPBBars1Leg   = input.int(12, "单腿最大时长(K)", group=grp_pb)
maxPBBars2Leg   = input.int(18, "二腿最大时长(K)", group=grp_pb)

grp_risk = "风险参数"
stopMaxSpike    = input.float(1.8, "Stop上限(Spike) x ATR", step=0.1, group=grp_risk)
stopMaxChannel  = input.float(1.5, "Stop上限(Channel) x ATR", step=0.1, group=grp_risk)
stopMaxLate     = input.float(1.2, "Stop上限(Late) x ATR", step=0.1, group=grp_risk)
stopMin         = input.float(0.35, "Stop下限 x ATR", step=0.05, group=grp_risk)
swingRRMin      = input.float(1.5, "Swing最低RR", step=0.1, group=grp_risk)

grp_session = "时段过滤"
useSessionFilter = input.bool(true, "启用时段过滤", group=grp_session)
sessionStart     = input.session("0935-1530", "交易时段 (ET)", group=grp_session)
lunchStart       = input.int(1130, "午盘开始(HHMM)", group=grp_session)
lunchEnd         = input.int(1300, "午盘结束(HHMM)", group=grp_session)

grp_viz = "可视化"
showLevels = input.bool(false, "显示水平参考线 (可能影响图表缩放)", group=grp_viz, tooltip="开启后会画出止损/止盈/Leg High/PB Low 等参考线。这些线参与 Y 轴自动缩放，可能压扁 K 线。如出现该问题，请保持关闭，仅依赖信号箭头与标签。")
showEntryStops = input.bool(true, "显示入场后的止损/止盈线 (持仓期间)", group=grp_viz)
showLegLines = input.bool(false, "显示 Leg High / PB Low 参考线", group=grp_viz)


// ══════════════════════════════════════════════════════════════════════════════
// 步骤 0：时段过滤
// ══════════════════════════════════════════════════════════════════════════════
currentHour = hour(time, "America/New_York")
currentMin  = minute(time, "America/New_York")
currentHHMM = currentHour * 100 + currentMin

// 黑名单：开盘5分钟、午盘、收盘前30分钟
isOpenBlackout = currentHHMM >= 930 and currentHHMM < 935
isLunchBlackout = currentHHMM >= lunchStart and currentHHMM < lunchEnd
isLateBlackout = currentHHMM >= 1530 and currentHHMM <= 1600

inTradingWindow = not isOpenBlackout and not isLunchBlackout and not isLateBlackout
inRTH = currentHHMM >= 935 and currentHHMM < 1530

sessionOK = useSessionFilter ? (inTradingWindow and inRTH) : true
warmupOK = bar_index >= warmupBars
systemAllowed = sessionOK and warmupOK


// ══════════════════════════════════════════════════════════════════════════════
// 基础指标计算
// ══════════════════════════════════════════════════════════════════════════════
ema20 = ta.ema(close, emaLen)
atr14 = ta.atr(atrLen)

// 1H EMA20 用于背景过滤
ema20_1H = request.security(syminfo.tickerid, "60", ta.ema(close, emaLen), barmerge.gaps_off, barmerge.lookahead_off)
ema20_1H_prev = request.security(syminfo.tickerid, "60", ta.ema(close, emaLen)[1], barmerge.gaps_off, barmerge.lookahead_off)
atr14_1H = request.security(syminfo.tickerid, "60", ta.atr(atrLen), barmerge.gaps_off, barmerge.lookahead_off)

// K线属性函数
barRange(i) => high[i] - low[i]
barBody(i) => math.abs(close[i] - open[i])
isBullClose(i) => close[i] > open[i]
isBearClose(i) => close[i] < open[i]

isStrongBullBar(i) => isBullClose(i) and close[i] >= low[i] + 0.70 * barRange(i) and barBody(i) >= 0.40 * atr14[i]

isStrongBearBar(i) => isBearClose(i) and close[i] <= low[i] + 0.30 * barRange(i) and barBody(i) >= 0.40 * atr14[i]


// ══════════════════════════════════════════════════════════════════════════════
// 步骤 1：1小时背景过滤
// ══════════════════════════════════════════════════════════════════════════════
// 1H EMA20 slope > 0
hourlyEmaRising = ema20_1H > ema20_1H_prev

// 1H 不处于大交易区间中段 (简化：用最近50根1H的最高最低)
highest_1H = request.security(syminfo.tickerid, "60", ta.highest(high, 50), barmerge.gaps_off, barmerge.lookahead_off)
lowest_1H  = request.security(syminfo.tickerid, "60", ta.lowest(low, 50), barmerge.gaps_off, barmerge.lookahead_off)
range_1H   = highest_1H - lowest_1H
midRange_1H = lowest_1H + range_1H * 0.5
inRangeMid_1H = range_1H > 3 * atr14_1H and close > lowest_1H + range_1H * 0.30 and close < lowest_1H + range_1H * 0.70

hourlyBackgroundOK = hourlyEmaRising and not inRangeMid_1H


// ══════════════════════════════════════════════════════════════════════════════
// 步骤 2：5分钟强多头趋势（5项条件）
// ══════════════════════════════════════════════════════════════════════════════

// 条件① EMA20 方向向上 (smoothed slope > 0.15)
slope1 = nz(atr14[1]) > 0 ? (ema20[1] - ema20[6]) / atr14[1] : 0
slope2 = nz(atr14[2]) > 0 ? (ema20[2] - ema20[7]) / atr14[2] : 0
slope3 = nz(atr14[3]) > 0 ? (ema20[3] - ema20[8]) / atr14[3] : 0
smoothedSlope = (slope1 + slope2 + slope3) / 3.0
directionUpOK = smoothedSlope > slopeThresh

// 条件② 价格持续接受在EMA20上方
countAboveEma = 0
maxConsecBelow = 0
consecBelow = 0
for i = 1 to priceAcceptBars
    if close[i] > ema20[i]
        countAboveEma += 1
        consecBelow := 0
    else
        consecBelow += 1
        maxConsecBelow := math.max(maxConsecBelow, consecBelow)
priceAcceptOK = countAboveEma >= priceAcceptMin and maxConsecBelow < 3

// 条件③ 多头K线质量合格
bullCloseCount = 0
strongBullCount = 0
for i = 1 to 12
    if isBullClose(i)
        bullCloseCount += 1
    if isStrongBullBar(i)
        strongBullCount += 1
bullBarQualityOK = bullCloseCount >= 7 and strongBullCount >= 3


// 条件④ 摆动结构偏多 (简化版 - 用 ta.pivothigh / ta.pivotlow)
// 2-bar pivot detection
pvtHigh2 = ta.pivothigh(high, 2, 2)  // 需要右侧2根确认
pvtLow2  = ta.pivotlow(low, 2, 2)

// 追踪最近两个有效摆动高/低点
var float lastSwingHigh = na
var float prevSwingHigh = na
var float lastSwingLow = na
var float prevSwingLow = na
var int lastSwingHighBar = 0
var int lastSwingLowBar = 0

if not na(pvtHigh2) and bar_index - lastSwingLowBar >= 3
    distH = na(lastSwingLow) ? atr14 : (pvtHigh2 - lastSwingLow)
    if distH >= 0.75 * atr14
        prevSwingHigh := lastSwingHigh
        lastSwingHigh := pvtHigh2
        lastSwingHighBar := bar_index - 2

if not na(pvtLow2) and bar_index - lastSwingHighBar >= 3
    distL = na(lastSwingHigh) ? atr14 : (lastSwingHigh - pvtLow2)
    if distL >= 0.75 * atr14
        prevSwingLow := lastSwingLow
        lastSwingLow := pvtLow2
        lastSwingLowBar := bar_index - 2

// Higher High OK (v2.0 放宽)
higherHighOK = na(prevSwingHigh) ? true : lastSwingHigh >= prevSwingHigh - 0.10 * atr14
// No break of major low
noBreakMajorLow = na(prevSwingLow) ? true : lastSwingLow >= prevSwingLow - 0.25 * atr14
swingStructureOK = higherHighOK and noBreakMajorLow


// 条件⑤ 无明显空头反转压力
// 检查最近5根是否有连续3根Strong_Bear_Bar
hasConsec3Bear = false
for i = 1 to 3
    if isStrongBearBar(i) and isStrongBearBar(i+1) and isStrongBearBar(i+2)
        hasConsec3Bear := true
noBearPressureOK = not hasConsec3Bear

// 总判定：强多头趋势
strongBullTrend = directionUpOK and priceAcceptOK and bullBarQualityOK and swingStructureOK and noBearPressureOK

// ══════════════════════════════════════════════════════════════════════════════
// 步骤 2.5：趋势相位识别
// ══════════════════════════════════════════════════════════════════════════════
// Spike: 最近5根中>=3根强多头K + 平均slope > 0.30
strongBullLast5 = 0
for i = 1 to 5
    if isStrongBullBar(i)
        strongBullLast5 += 1

avgSlope5 = (slope1 + slope2 + slope3) / 3.0  // 重用smoothedSlope
isSpikePhase = strongBullTrend and strongBullLast5 >= 3 and smoothedSlope > spikeSlope

// Late Channel: 简化检测 - 最近摆动高点收敛 OR 接近1H高点
isNear1HHigh = not na(highest_1H) and not na(atr14_1H) and (highest_1H - close) < 0.5 * atr14_1H
isLateChannel = strongBullTrend and not isSpikePhase and isNear1HHigh

// Channel: 正常通道
isChannelPhase = strongBullTrend and not isSpikePhase and not isLateChannel and smoothedSlope >= slopeThresh and smoothedSlope <= spikeSlope

// Range/Barbwire
isRangePhase = not strongBullTrend

// 相位允许H2
phaseAllowsH2 = isSpikePhase or isChannelPhase or isLateChannel


// ══════════════════════════════════════════════════════════════════════════════
// 步骤 3：健康回调 + 二腿识别
// ══════════════════════════════════════════════════════════════════════════════
// Leg 结构跟踪
var float legStart = na     // 最近主要摆动低点
var float legHigh = na      // Leg_Start之后最高点
var int legHighBarIdx = 0   // Leg_High所在bar_index
var float currentPBLow = na // 回调低点
var int pbStartBarIdx = 0   // 回调开始的bar_index

// 更新 legStart (使用最近的摆动低点)
if not na(lastSwingLow) and (na(legStart) or lastSwingLow != legStart)
    // 检查是否是MajorSwingLow: 之后30根内最高 - low >= 1.25*ATR
    maxAfter = ta.highest(high, 30)
    if not na(lastSwingLow) and (maxAfter - lastSwingLow) >= 1.25 * atr14
        legStart := lastSwingLow

// 更新 legHigh
if not na(legStart)
    if na(legHigh) or high > legHigh
        legHigh := high
        legHighBarIdx := bar_index

// 回调判断：从 legHigh 开始价格下行
isPullingBack = not na(legHigh) and close < legHigh and bar_index > legHighBarIdx

// 更新回调低点
if isPullingBack
    if na(currentPBLow) or low < currentPBLow
        currentPBLow := low
    if pbStartBarIdx == 0
        pbStartBarIdx := legHighBarIdx
else
    if not na(legHigh) and close > legHigh
        // 新高了，重置回调
        currentPBLow := na
        pbStartBarIdx := 0


// 回调深度和时长
legRange = na(legHigh) or na(legStart) ? 0.0 : legHigh - legStart
pullbackDepth = na(legHigh) or na(currentPBLow) ? 0.0 : legHigh - currentPBLow
pullbackRatio = legRange > 0 ? pullbackDepth / legRange : 0.0
pullbackBars = bar_index - legHighBarIdx

// 二腿回调简化检测：回调内是否有反弹再下跌的结构
// 如果回调bars >= 6 且中间出现了反弹(至少1根多头close高于前根)再回落
var bool twoLeggedPB = false
if isPullingBack and pullbackBars >= 6
    // 简化：检查回调区间内是否有ValidSwingHigh (即B腿反弹)
    midBounce = false
    for i = 2 to math.min(pullbackBars - 2, 15)
        if high[i] > high[i+1] and high[i] > high[i-1] and high[i] < legHigh - 0.25 * atr14
            midBounce := true
            break
    twoLeggedPB := midBounce
else
    twoLeggedPB := false

// 动态参数
maxPBRatio = twoLeggedPB ? maxPBRatio2Leg : maxPBRatio1Leg
maxPBTime = twoLeggedPB ? maxPBBars2Leg : maxPBBars1Leg

// 回调内无连续3根强空头
bearConsecInPB = false
checkLen = math.min(pullbackBars, 10)
if checkLen >= 3
    for i = 1 to checkLen - 2
        if isStrongBearBar(i) and isStrongBearBar(i+1) and isStrongBearBar(i+2)
            bearConsecInPB := true
            break

// 健康回调判定
healthyPullback = isPullingBack and pullbackRatio < maxPBRatio and pullbackRatio > 0 and (na(legStart) ? true : currentPBLow > legStart) and not bearConsecInPB and pullbackBars <= maxPBTime and pullbackDepth >= 0.25 * atr14


// ══════════════════════════════════════════════════════════════════════════════
// 步骤 4-6：H1/H2 识别状态机
// ══════════════════════════════════════════════════════════════════════════════
// H1: 回调后第一次突破前一根K高点的向上尝试
// H2: H1弱/失败后第二次突破前一根K高点

// 信号K质量检测
isH1QualityOK(i) => not isStrongBearBar(i) and close[i] >= low[i] + 0.40 * barRange(i)

isH2QualityOK(i) => isBullClose(i) and not isStrongBearBar(i) and close[i] >= low[i] + 0.40 * barRange(i)

// 突破前一根K高点检测 (当前已收盘bar[1]高点 > bar[2]高点)
breakAbovePrior = high[1] > high[2]

// 非高位噪音检测
notHighNoise = na(legHigh) ? true : not (math.abs(close[1] - legHigh) < 0.25 * atr14 and pullbackDepth < 0.50 * atr14)

// 近期无强空头压制
recentBearCount = 0
for i = 1 to 3
    if isStrongBearBar(i)
        recentBearCount += 1
noRecentBearPressure = recentBearCount < 2

// H1/H2 状态机
var int tradeState = 0  // 0=等待, 1=H1已识别等待结果, 2=H1弱等H2, 3=H2已出信号, 4=已入场
var float h1High = na
var int h1BarIdx = 0
var float h2High = na
var int h2BarIdx = 0
var int h2SignalBarIdx = 0


// 新信号条件（基础）
baseCondition = systemAllowed and hourlyBackgroundOK and strongBullTrend and phaseAllowsH2 and healthyPullback

// H1 检测
h1Detected = baseCondition and tradeState == 0 and breakAbovePrior and isH1QualityOK(1) and notHighNoise and noRecentBearPressure and pullbackBars >= 2

// H1成功判定 (Strong Follow Through: 强多头收盘且>H1高点)
h1Success = tradeState == 1 and bar_index - h1BarIdx <= 2 and ((isStrongBullBar(1) and close[1] > h1High) or (close[1] > legHigh))

// H1弱/失败
h1WeakOrFail = tradeState == 1 and bar_index - h1BarIdx > 2 and not h1Success

// H2 检测
h2Detected = baseCondition and tradeState == 2 and breakAbovePrior and isH2QualityOK(1) and noRecentBearPressure

// 状态转移
if h1Detected and tradeState == 0
    tradeState := 1
    h1High := high[1]
    h1BarIdx := bar_index

if h1Success and tradeState == 1
    // H1成功，高质量H1可直接触发（本指标版本简化为不入场，仅标记）
    tradeState := 0  // 重置，本版只做H2

if h1WeakOrFail and tradeState == 1
    tradeState := 2  // 等待H2

if h2Detected and tradeState == 2
    tradeState := 3
    h2High := high[1]
    h2BarIdx := bar_index
    h2SignalBarIdx := bar_index


// ══════════════════════════════════════════════════════════════════════════════
// 步骤 7-8：风险检查 + 入场触发
// ══════════════════════════════════════════════════════════════════════════════
tickSize = syminfo.mintick
var float entryPrice = na
var float initialStop = na
var float stopDistance = na
var float riskR = na
var float scalpTarget = na
var float swingTarget = na
var float swingTargetExt = na
var bool isScalpOnly = false
var bool entryTriggered = false
var int entryBarIdx = 0

// Buy Stop 有效期 (按相位)
buyStopValidBars = isSpikePhase or isLateChannel ? 1 : 2

// 计算入场参数（当H2信号出现时）
if tradeState == 3 and bar_index == h2SignalBarIdx
    entryPrice := h2High + tickSize
    initialStop := low[1] - tickSize  // H2信号K的低点
    stopDistance := entryPrice - initialStop
    riskR := stopDistance
    
    // 止损上下限检查
    maxStopLimit = isSpikePhase ? stopMaxSpike * atr14 : isChannelPhase ? stopMaxChannel * atr14 : stopMaxLate * atr14
    stopOK = stopDistance <= maxStopLimit and stopDistance >= stopMin * atr14
    
    // 结构止损检查
    structOK = na(currentPBLow) ? true : (initialStop <= currentPBLow or math.abs(initialStop - currentPBLow) <= 0.25 * atr14)
    
    // 仓位模式
    legHighDist = na(legHigh) ? atr14 : (legHigh - entryPrice)
    swingRR = riskR > 0 ? legHighDist / riskR : 0
    isScalpOnly := isLateChannel or legHighDist < 0.5 * atr14 or swingRR < swingRRMin
    
    // 止盈目标
    scalpTarget := entryPrice + 1.0 * riskR
    swingTarget := na(legHigh) ? entryPrice + 2.0 * riskR : legHigh
    swingTargetExt := na(currentPBLow) or na(legHigh) or na(legStart) ? entryPrice + 3.0 * riskR : currentPBLow + (legHigh - legStart)
    
    // 风险检查不通过则取消
    if not stopOK or not structOK
        tradeState := 0
        entryPrice := na


// Buy Stop 触发检测
if tradeState == 3 and not na(entryPrice)
    barsSinceSignal = bar_index - h2SignalBarIdx
    if barsSinceSignal >= 1 and barsSinceSignal <= buyStopValidBars
        // 当前bar的high是否触及入场价（在已收盘bar上检查）
        if high[1] >= entryPrice
            entryTriggered := true
            entryBarIdx := bar_index - 1
            tradeState := 4
    if barsSinceSignal > buyStopValidBars and tradeState == 3
        // 超时撤单
        tradeState := 0
        entryPrice := na

// ══════════════════════════════════════════════════════════════════════════════
// 步骤 9-10：入场后管理（止损、止盈、移动止损）
// ══════════════════════════════════════════════════════════════════════════════
var float activeStop = na
var float activeScalp = na
var float activeSwing = na
var bool tradeActive = false
var bool scalpHit = false
var bool swingMode = false
var int barsInTrade = 0

// 入场确认
if entryTriggered and not tradeActive
    tradeActive := true
    activeStop := initialStop
    activeScalp := scalpTarget
    activeSwing := isScalpOnly ? na : swingTargetExt
    scalpHit := false
    swingMode := not isScalpOnly
    barsInTrade := 0
    entryTriggered := false


// 交易管理
var bool stopHitSignal = false
var bool scalpHitSignal = false
var bool swingHitSignal = false
var bool defensiveExitSignal = false

stopHitSignal := false
scalpHitSignal := false
swingHitSignal := false
defensiveExitSignal := false

if tradeActive
    barsInTrade += 1
    
    // 止损检测
    if not na(activeStop) and low[1] <= activeStop
        stopHitSignal := true
        tradeActive := false
        tradeState := 0
    
    // Scalp 止盈检测
    if not scalpHit and not na(activeScalp) and high[1] >= activeScalp
        scalpHitSignal := true
        scalpHit := true
        if not swingMode
            // Scalp Only 模式，全平
            tradeActive := false
            tradeState := 0
    
    // Swing 止盈检测
    if swingMode and scalpHit and not na(activeSwing) and high[1] >= activeSwing
        swingHitSignal := true
        tradeActive := false
        tradeState := 0
    
    // 移动止损逻辑
    if tradeActive and scalpHit and swingMode
        // 阶段1：Scalp达成后保本
        activeStop := math.max(nz(activeStop), entryPrice - tickSize)
        // 阶段2：突破前高
        if not na(legHigh) and close[1] > legHigh
            newStop = math.max(entryPrice - tickSize, legHigh - 0.25 * atr14, math.min(low[1], low[2]) - tickSize)
            activeStop := math.max(nz(activeStop), newStop)
        // 阶段3：跟踪摆动低点
        if not na(lastSwingLow)
            activeStop := math.max(nz(activeStop), lastSwingLow - tickSize)


    // 防守退出
    defTimeLimit = isSpikePhase or isLateChannel ? 6 : 10
    maxUnrealizedR = not na(entryPrice) and riskR > 0 ? (high[1] - entryPrice) / riskR : 0
    
    // Failed follow through
    failedFollow = barsInTrade <= 2 and close[1] <= entryPrice and isStrongBearBar(1)
    // 跌破回调低点
    breakPBLow = not na(currentPBLow) and close[1] < currentPBLow
    // EMA下方 + 强空头
    emaBearBreak = close[1] < ema20[1] and isStrongBearBar(1)
    // 动能失速
    momentumStall = barsInTrade >= defTimeLimit and maxUnrealizedR < 0.5
    
    if tradeActive and (failedFollow or breakPBLow or emaBearBreak or momentumStall)
        defensiveExitSignal := true
        tradeActive := false
        tradeState := 0

// 交易结束后重置
if not tradeActive and tradeState == 0
    if not stopHitSignal and not scalpHitSignal and not swingHitSignal and not defensiveExitSignal
        entryPrice := na
        initialStop := na
        activeStop := na
        activeScalp := na
        activeSwing := na
        barsInTrade := 0


// ══════════════════════════════════════════════════════════════════════════════
// 可视化
// ══════════════════════════════════════════════════════════════════════════════

// EMA20
plot(ema20, "EMA20", color=color.new(color.blue, 20), linewidth=2)

// 相位背景色
bgColor = isSpikePhase ? color.new(color.green, 92) : isChannelPhase ? color.new(color.teal, 95) : isLateChannel ? color.new(color.orange, 92) : na
bgcolor(strongBullTrend ? bgColor : na, title="趋势相位")

// H2 信号标记（买入信号）
h2Signal = tradeState == 3 and bar_index == h2SignalBarIdx
plotshape(h2Signal, title="H2 买入信号", style=shape.triangleup, location=location.belowbar, color=color.green, size=size.normal, text="H2")

// H1 标记
h1Signal = tradeState == 1 and bar_index == h1BarIdx
plotshape(h1Signal, title="H1 标记", style=shape.circle, location=location.belowbar, color=color.new(color.blue, 30), size=size.tiny, text="H1")

// 入场确认标记
plotshape(tradeActive and barsInTrade == 1, title="入场确认", style=shape.labelup, location=location.belowbar, color=color.new(color.green, 0), size=size.small, text="BUY")

// 止损线 & 止盈线 (默认仅在持仓期间显示，可在输入设置中关闭)
plot(showEntryStops and tradeActive ? activeStop : na, "止损线", color=color.red, linewidth=2, style=plot.style_linebr)
plot(showEntryStops and tradeActive and not scalpHit ? activeScalp : na, "Scalp目标", color=color.new(color.green, 30), linewidth=1, style=plot.style_linebr)
plot(showEntryStops and tradeActive and swingMode ? activeSwing : na, "Swing目标", color=color.new(color.purple, 30), linewidth=1, style=plot.style_linebr)
plot(showEntryStops and not na(entryPrice) and tradeActive ? entryPrice : na, "入场价", color=color.new(color.gray, 40), linewidth=1, style=plot.style_linebr)


// 退出信号标记
plotshape(stopHitSignal, title="止损", style=shape.xcross, location=location.abovebar, color=color.red, size=size.small, text="STOP")
plotshape(scalpHitSignal, title="Scalp止盈", style=shape.flag, location=location.abovebar, color=color.green, size=size.small, text="TP1")
plotshape(swingHitSignal, title="Swing止盈", style=shape.flag, location=location.abovebar, color=color.purple, size=size.small, text="TP2")
plotshape(defensiveExitSignal, title="防守退出", style=shape.xcross, location=location.abovebar, color=color.orange, size=size.small, text="DEF")

// Leg结构显示 (默认关闭，避免影响图表缩放)
plot(showLegLines and isPullingBack and not na(legHigh) ? legHigh : na, "Leg High", color=color.new(color.teal, 50), linewidth=1, style=plot.style_linebr)
plot(showLegLines and isPullingBack and not na(currentPBLow) ? currentPBLow : na, "PB Low", color=color.new(color.red, 60), linewidth=1, style=plot.style_linebr)

// ══════════════════════════════════════════════════════════════════════════════
// Alert 条件
// ══════════════════════════════════════════════════════════════════════════════
alertcondition(h2Signal, title="H2 买入信号", message="H2 Long Signal! Entry: {{close}} + 1 tick above signal bar high")
alertcondition(tradeActive and barsInTrade == 1, title="入场确认", message="H2 Buy Stop Filled @ approx {{close}}")
alertcondition(stopHitSignal, title="止损触发", message="H2 Trade STOPPED OUT")
alertcondition(scalpHitSignal, title="Scalp止盈", message="Scalp Target Hit (+1R)")
alertcondition(swingHitSignal, title="Swing止盈", message="Swing Target Hit - Full Exit")
alertcondition(defensiveExitSignal, title="防守退出", message="Defensive Exit Triggered")

// ══════════════════════════════════════════════════════════════════════════════
// 信息面板
// ══════════════════════════════════════════════════════════════════════════════
var table infoPanel = table.new(position.top_right, 2, 10, bgcolor=color.new(color.black, 80), border_width=1)
if barstate.islast
    phaseStr = isSpikePhase ? "🟢 Spike" : isChannelPhase ? "🔵 Channel" : isLateChannel ? "🟠 Late Ch" : "⚪ Range"
    trendStr = strongBullTrend ? "✅ Strong Bull" : "❌ No Trend"
    pbStr = healthyPullback ? "✅ " + str.tostring(pullbackRatio, "#.##") : "❌"
    stateStr = tradeState == 0 ? "等待" : tradeState == 1 ? "H1观察" : tradeState == 2 ? "等H2" : tradeState == 3 ? "H2挂单" : "持仓中"
    
    table.cell(infoPanel, 0, 0, "相位", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 0, phaseStr, text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 0, 1, "趋势", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 1, trendStr, text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 0, 2, "回调", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 2, pbStr, text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 0, 3, "Slope", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 3, str.tostring(smoothedSlope, "#.###"), text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 0, 4, "状态", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 4, stateStr, text_color=color.yellow, text_size=size.small)
    table.cell(infoPanel, 0, 5, "1H背景", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 5, hourlyBackgroundOK ? "✅" : "❌", text_color=color.white, text_size=size.small)
