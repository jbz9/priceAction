  <diagram name="L2-failed-bounce-30s-flow" id="L2flow">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="L2 失败反弹判断 — 30 秒决策流程&#xa;(对应做空方法论 §4.1)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="450" height="50" as="geometry" />
        </mxCell>
        <mxCell id="legend" value="图例:&#xa;🟦 起点  🟨 决策  🟩 形态  🟧 等待  🟥 放弃出口  🟢 通过出口" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="320" height="50" as="geometry" />
        </mxCell>
        <mxCell id="start" value="反弹接近阻力&#xa;(Asia.H / EMA20 / VWAP / PDH)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="430" y="100" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="Step 1 (5 秒)&#xa;已触及关键阻力?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="450" y="200" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="wait1" value="⚠️ 等待&#xa;距阻力 > 0.5 ATR&#xa;下根 K 后重新评估" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3cd;strokeColor=#ad6800;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="120" y="220" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="x1" value="🛑 放弃&#xa;已远超阻力&#xa;这是【突破】不是【反弹】&#xa;不要做空" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="820" y="210" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="Step 2 (10 秒)&#xa;之前已经有【一次】&#xa;失败尝试?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="450" y="350" width="240" height="110" as="geometry" />
        </mxCell>
        <mxCell id="x2" value="🛑 放弃&#xa;这是 H1/L1 (第 1 次)&#xa;Brooks 80% rule:&#xa;第 1 次有 80% 失败概率&#xa;但你不知是不是那 20%&#xa;等真失败再说" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="820" y="360" width="220" height="100" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="Step 3 (10 秒)&#xa;当前是哪种形态?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="450" y="510" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="f1" value="📌 #1&#xa;2 根反转&#xa;Two-Bar Reversal&#xa;胜率 55-60%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="40" y="680" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="f2" value="📌 #2&#xa;双顶&#xa;Double Top&#xa;胜率 60-65%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="220" y="680" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="f3" value="📌 #3&#xa;失败突破&#xa;Failed Breakout&#xa;胜率 65%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="400" y="680" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="f4" value="📌 #4&#xa;楔形 3 推&#xa;Wedge Top&#xa;胜率 65-70%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="580" y="680" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="f5" value="📌 #5&#xa;Climactic 衰竭&#xa;Climactic Exhaustion&#xa;胜率 55-60%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="760" y="680" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="x3" value="🛑 放弃&#xa;不是失败动作&#xa;只是噪音 / 横盘&#xa;不要做空" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="940" y="680" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="Step 4 (5 秒)&#xa;4 硬指标全部满足?&#xa;✓ 实体 ≥ 0.5 × ATR&#xa;✓ close 在下 30%&#xa;✓ 多周期 AIS (≥ 2 致)&#xa;✓ 距下方支撑 ≥ 1.5R" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="380" y="830" width="380" height="180" as="geometry" />
        </mxCell>
        <mxCell id="x4" value="🛑 放弃&#xa;力度不足&#xa;不是高概率 setup&#xa;再好的形态也得有硬指标" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="820" y="870" width="220" height="100" as="geometry" />
        </mxCell>
        <mxCell id="go" value="✅ 通过 — 进入 8 阶段卡片&#xa;Phase 4 (止损) → Phase 5 (止盈)&#xa;→ Phase 6 (持仓) → Phase 7 (复盘)&#xa;&#xa;入场: 信号 K close - 1 tick (Sell Stop)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;strokeWidth=4;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="380" y="1080" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="finalnote" value="🛑 任何阶段任意一步 ❌ → 全程取消&#xa;6 个放弃出口 vs 1 个通过出口 = 6:1 否决率&#xa;这就是【概率交易】的本质 — 你大部分时间在【说不】" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;fontStyle=2;fillColor=#fafafa;strokeColor=#666666" vertex="1" parent="1">
          <mxGeometry x="280" y="1240" width="580" height="80" as="geometry" />
